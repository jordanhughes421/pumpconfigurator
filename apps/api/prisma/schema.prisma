generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// §5.1 Core Pump Tables
// =============================================================================

model PumpFamily {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  hiTypeCode  String   @map("hi_type_code") @db.VarChar(10)
  flowRegime  String   @map("flow_regime") @db.VarChar(20)
  orientation String   @db.VarChar(20)
  staging     String   @db.VarChar(20)
  description String?  @db.Text
  imageUrl    String?  @map("image_url") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  models PumpModel[]

  @@index([hiTypeCode, flowRegime], map: "idx_family_hi_type")
  @@map("pump_family")
}

model PumpModel {
  id              String   @id @default(uuid())
  familyId        String   @map("family_id")
  modelCode       String   @map("model_code") @db.VarChar(50)
  frameSize       String?  @map("frame_size") @db.VarChar(20)
  suctionSizeMm   Int?     @map("suction_size_mm")
  dischargeSizeMm Int?     @map("discharge_size_mm")
  maxImpellerMm   Decimal  @map("max_impeller_mm") @db.Decimal(8, 2)
  minImpellerMm   Decimal  @map("min_impeller_mm") @db.Decimal(8, 2)
  ratedSpeedRpm   Int      @map("rated_speed_rpm")
  maxStages       Int      @default(1) @map("max_stages")
  minStages       Int      @default(1) @map("min_stages")
  maxPowerKw      Decimal? @map("max_power_kw") @db.Decimal(10, 2)
  maxTemperatureC Decimal? @map("max_temperature_c") @db.Decimal(6, 1)
  maxPressureBar  Decimal? @map("max_pressure_bar") @db.Decimal(8, 2)
  weightKg        Decimal? @map("weight_kg") @db.Decimal(10, 2)

  family     PumpFamily          @relation(fields: [familyId], references: [id])
  sizes      PumpSize[]
  motors     PumpModelMotor[]
  baseplates PumpModelBaseplate[]
  impellerGeometries ImpellerGeometry[]
  voluteGeometries   VoluteGeometry[]

  @@unique([familyId, modelCode])
  @@map("pump_model")
}

model PumpSize {
  id                 String   @id @default(uuid())
  modelId            String   @map("model_id")
  sizeDesignation    String   @map("size_designation") @db.VarChar(50)
  impellerDiameterMm Decimal  @map("impeller_diameter_mm") @db.Decimal(8, 2)
  numStages          Int      @default(1) @map("num_stages")
  ratedFlowM3h       Decimal? @map("rated_flow_m3h") @db.Decimal(10, 2)
  ratedHeadM         Decimal? @map("rated_head_m") @db.Decimal(10, 2)
  ratedEfficiency    Decimal? @map("rated_efficiency") @db.Decimal(5, 2)
  ratedPowerKw       Decimal? @map("rated_power_kw") @db.Decimal(10, 2)
  ratedNpshrM        Decimal? @map("rated_npshr_m") @db.Decimal(6, 2)
  specificSpeedUs    Decimal? @map("specific_speed_us") @db.Decimal(10, 1)
  minFlowM3h         Decimal? @map("min_flow_m3h") @db.Decimal(10, 2)
  maxFlowM3h         Decimal? @map("max_flow_m3h") @db.Decimal(10, 2)
  speedRpm           Int      @map("speed_rpm")

  model             PumpModel             @relation(fields: [modelId], references: [id])
  curveSets         PerformanceCurveSet[]
  configurations    PumpConfigurationRecord[]

  @@unique([modelId, sizeDesignation])
  @@index([ratedFlowM3h, ratedHeadM, minFlowM3h, maxFlowM3h], map: "idx_size_operating_envelope")
  @@map("pump_size")
}

// =============================================================================
// §5.1 Performance Curve Tables
// =============================================================================

model PerformanceCurveSet {
  id                 String   @id @default(uuid())
  sizeId             String   @map("size_id")
  speedRpm           Int      @map("speed_rpm")
  impellerDiameterMm Decimal  @map("impeller_diameter_mm") @db.Decimal(8, 2)
  fluidSg            Decimal  @default(1.0) @map("fluid_sg") @db.Decimal(6, 4)
  viscosityCst       Decimal  @default(1.0) @map("viscosity_cst") @db.Decimal(10, 2)
  testDate           DateTime? @map("test_date") @db.Date
  source             String   @default("catalog") @db.VarChar(20)
  isReference        Boolean  @default(false) @map("is_reference")

  size   PumpSize   @relation(fields: [sizeId], references: [id])
  curves CurveData[]
  testResults GeometryTestResult[]

  @@unique([sizeId, speedRpm, impellerDiameterMm])
  @@index([sizeId, isReference], map: "idx_curve_set_lookup")
  @@map("performance_curve_set")
}

model CurveData {
  id             String  @id @default(uuid())
  curveSetId     String  @map("curve_set_id")
  curveType      String  @map("curve_type") @db.VarChar(10)
  representation String  @db.VarChar(20)
  coefficients   Json?
  degree         Int?
  knotsX         Json?   @map("knots_x")
  knotsY         Json?   @map("knots_y")
  dataPoints     Json?   @map("data_points")
  xUnit          String  @default("m3/h") @map("x_unit") @db.VarChar(10)
  yUnit          String? @map("y_unit") @db.VarChar(10)
  validQMin      Decimal? @map("valid_q_min") @db.Decimal(10, 2)
  validQMax      Decimal? @map("valid_q_max") @db.Decimal(10, 2)

  curveSet PerformanceCurveSet @relation(fields: [curveSetId], references: [id])

  @@unique([curveSetId, curveType])
  @@map("curve_data")
}

// =============================================================================
// §5.2 Component & Material Tables
// =============================================================================

model ComponentDefinition {
  id                 String  @id @default(uuid())
  hiTypeCode         String  @map("hi_type_code") @db.VarChar(10)
  componentKey       String  @map("component_key") @db.VarChar(50)
  displayName        String  @map("display_name") @db.VarChar(100)
  displayOrder       Int     @map("display_order")
  isWetted           Boolean @map("is_wetted")
  isPressureBoundary Boolean @default(false) @map("is_pressure_boundary")
  isPerStage         Boolean @default(false) @map("is_per_stage")
  isRequired         Boolean @default(true) @map("is_required")
  notes              String? @db.Text

  materialOptions ComponentMaterialOption[]

  @@unique([hiTypeCode, componentKey])
  @@index([hiTypeCode, displayOrder], map: "idx_component_def_type")
  @@map("component_definition")
}

model Material {
  id                      String   @id @default(uuid())
  materialCode            String   @unique @map("material_code") @db.VarChar(30)
  commonName              String   @map("common_name") @db.VarChar(100)
  specification           String?  @db.VarChar(100)
  unsNumber               String?  @map("uns_number") @db.VarChar(10)
  materialGroup           String   @map("material_group") @db.VarChar(30)
  maxTemperatureC         Decimal? @map("max_temperature_c") @db.Decimal(6, 1)
  maxPressureBar          Decimal? @map("max_pressure_bar") @db.Decimal(8, 2)
  leadContentPct          Decimal? @map("lead_content_pct") @db.Decimal(6, 4)
  isFerrous               Boolean? @map("is_ferrous")
  domesticSourceAvailable Boolean  @default(true) @map("domestic_source_available")
  densityKgM3             Decimal? @map("density_kg_m3") @db.Decimal(10, 2)
  // Wear ring data (from Appendix B.12)
  hardnessMinBhn          Decimal? @map("hardness_min_bhn") @db.Decimal(6, 1)
  hardnessMaxBhn          Decimal? @map("hardness_max_bhn") @db.Decimal(6, 1)
  isHardenable            Boolean  @default(false) @map("is_hardenable")
  hardeningMethods        String?  @map("hardening_methods") @db.VarChar(200)
  hardenedMinBhn          Decimal? @map("hardened_min_bhn") @db.Decimal(6, 1)
  hardenedMaxBhn          Decimal? @map("hardened_max_bhn") @db.Decimal(6, 1)
  hardenedMaxHrc          Decimal? @map("hardened_max_hrc") @db.Decimal(4, 1)
  notes                   String?  @db.Text

  materialOptions    ComponentMaterialOption[]
  certifications     MaterialCertification[]
  materialSelections ComponentMaterialSelectionRecord[]

  @@map("material")
}

model ComponentMaterialOption {
  id             String  @id @default(uuid())
  componentDefId String  @map("component_def_id")
  materialId     String  @map("material_id")
  modelId        String? @map("model_id")
  isDefault      Boolean @default(false) @map("is_default")
  isStandard     Boolean @default(true) @map("is_standard")
  costTier       Int     @default(1) @map("cost_tier")
  notes          String? @db.Text

  componentDef ComponentDefinition @relation(fields: [componentDefId], references: [id])
  material     Material            @relation(fields: [materialId], references: [id])

  @@unique([componentDefId, materialId, modelId])
  @@index([componentDefId, materialId], map: "idx_component_material")
  @@map("component_material_option")
}

// =============================================================================
// §5.3 Certification Tables
// =============================================================================

model Certification {
  id                     String  @id @default(uuid())
  code                   String  @unique @db.VarChar(30)
  fullName               String  @map("full_name") @db.VarChar(200)
  category               String? @db.VarChar(30)
  description            String? @db.Text
  isMaterialConstraining Boolean @default(true) @map("is_material_constraining")
  isSourcingConstraining Boolean @default(false) @map("is_sourcing_constraining")
  isDocumentationOnly    Boolean @default(false) @map("is_documentation_only")
  mutualRequirements     String? @map("mutual_requirements") @db.VarChar(200)

  materialCertifications     MaterialCertification[]
  motorConstraints           CertificationMotorConstraint[]
  baseplateConstraints       CertificationBaseplateConstraint[]

  @@map("certification")
}

model MaterialCertification {
  id                    String   @id @default(uuid())
  materialId            String   @map("material_id")
  certificationId       String   @map("certification_id")
  componentKey          String?  @map("component_key") @db.VarChar(50)
  isCertified           Boolean  @default(true) @map("is_certified")
  certificationNumber   String?  @map("certification_number") @db.VarChar(100)
  expirationDate        DateTime? @map("expiration_date") @db.Date
  requiresCoating       Boolean  @default(false) @map("requires_coating")
  coatingSpecification  String?  @map("coating_specification") @db.VarChar(100)
  notes                 String?  @db.Text

  material      Material      @relation(fields: [materialId], references: [id])
  certification Certification @relation(fields: [certificationId], references: [id])

  @@unique([materialId, certificationId, componentKey])
  @@index([certificationId, componentKey, isCertified], map: "idx_material_cert_lookup")
  @@map("material_certification")
}

model CertificationMotorConstraint {
  id              String @id @default(uuid())
  certificationId String @map("certification_id")
  constraintType  String @map("constraint_type") @db.VarChar(30)
  parameter       String @db.VarChar(50)
  operator        String @db.VarChar(10)
  value           Json

  certification Certification @relation(fields: [certificationId], references: [id])

  description String? @db.Text

  @@map("certification_motor_constraint")
}

model CertificationBaseplateConstraint {
  id              String @id @default(uuid())
  certificationId String @map("certification_id")
  constraintType  String @map("constraint_type") @db.VarChar(30)
  parameter       String @db.VarChar(50)
  operator        String @db.VarChar(10)
  value           Json

  certification Certification @relation(fields: [certificationId], references: [id])

  description String? @db.Text

  @@map("certification_baseplate_constraint")
}

// =============================================================================
// §5.4 Motor & Baseplate Tables
// =============================================================================

model MotorOption {
  id                    String   @id @default(uuid())
  manufacturer          String?  @db.VarChar(100)
  modelNumber           String?  @map("model_number") @db.VarChar(100)
  powerKw               Decimal  @map("power_kw") @db.Decimal(10, 2)
  powerHp               Decimal? @map("power_hp") @db.Decimal(10, 2)
  speedRpm              Int      @map("speed_rpm")
  poles                 Int
  voltage               String   @db.VarChar(20)
  phase                 Int
  frequencyHz           Int      @map("frequency_hz")
  enclosure             String   @db.VarChar(30)
  frame                 String   @db.VarChar(20)
  efficiencyClass       String?  @map("efficiency_class") @db.VarChar(10)
  fullLoadEfficiency    Decimal? @map("full_load_efficiency") @db.Decimal(5, 2)
  serviceFactor         Decimal  @default(1.15) @map("service_factor") @db.Decimal(4, 2)
  insulationClass       String   @default("F") @map("insulation_class") @db.VarChar(2)
  isInverterDuty        Boolean  @default(false) @map("is_inverter_duty")
  mounting              String?  @db.VarChar(10)
  weightKg              Decimal? @map("weight_kg") @db.Decimal(10, 2)
  isVertical            Boolean  @default(false) @map("is_vertical")
  isHollowShaft         Boolean  @default(false) @map("is_hollow_shaft")
  isSubmersible         Boolean  @default(false) @map("is_submersible")
  hazardousClass        String?  @map("hazardous_class") @db.VarChar(30)
  ulListed              Boolean  @default(false) @map("ul_listed")
  fmApproved            Boolean  @default(false) @map("fm_approved")
  domesticManufactured  Boolean  @default(false) @map("domestic_manufactured")

  pumpModels     PumpModelMotor[]
  configurations PumpConfigurationRecord[] @relation("ConfigurationMotor")

  @@index([ulListed, fmApproved, hazardousClass, domesticManufactured], map: "idx_motor_cert")
  @@map("motor_option")
}

model BaseplateOption {
  id                    String  @id @default(uuid())
  type                  String  @db.VarChar(50)
  material              String  @db.VarChar(50)
  applicableHiTypes     Json?   @map("applicable_hi_types")
  hasDripRim            Boolean @default(false) @map("has_drip_rim")
  hasDrain              Boolean @default(false) @map("has_drain")
  groutType             String? @map("grout_type") @db.VarChar(30)
  domesticManufactured  Boolean @default(false) @map("domestic_manufactured")
  description           String? @db.Text

  pumpModels     PumpModelBaseplate[]
  configurations PumpConfigurationRecord[] @relation("ConfigurationBaseplate")

  @@map("baseplate_option")
}

model PumpModelMotor {
  modelId       String   @map("model_id")
  motorOptionId String   @map("motor_option_id")
  isDefault     Boolean  @default(false) @map("is_default")
  minImpellerMm Decimal? @map("min_impeller_mm") @db.Decimal(8, 2)
  maxImpellerMm Decimal? @map("max_impeller_mm") @db.Decimal(8, 2)

  model PumpModel   @relation(fields: [modelId], references: [id])
  motor MotorOption @relation(fields: [motorOptionId], references: [id])

  @@id([modelId, motorOptionId])
  @@map("pump_model_motor")
}

model PumpModelBaseplate {
  modelId     String  @map("model_id")
  baseplateId String  @map("baseplate_id")
  isDefault   Boolean @default(false) @map("is_default")

  model     PumpModel      @relation(fields: [modelId], references: [id])
  baseplate BaseplateOption @relation(fields: [baseplateId], references: [id])

  @@id([modelId, baseplateId])
  @@map("pump_model_baseplate")
}

// =============================================================================
// §5.5 Project & Configuration Tables
// =============================================================================

model Project {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(200)
  description    String?  @db.Text
  certifications Json     @default("[]")
  cmtrLevel      String   @default("none") @map("cmtr_level") @db.VarChar(10)
  defaultUnits   String   @default("metric") @map("default_units") @db.VarChar(10)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  configurations PumpConfigurationRecord[]

  @@map("project")
}

model PumpConfigurationRecord {
  id                 String   @id @default(uuid())
  projectId          String   @map("project_id")
  tagNumber          String?  @map("tag_number") @db.VarChar(50)
  service            String?  @db.VarChar(200)
  pumpSizeId         String   @map("pump_size_id")
  motorOptionId      String?  @map("motor_option_id")
  baseplateId        String?  @map("baseplate_id")
  impellerTrimMm     Decimal? @map("impeller_trim_mm") @db.Decimal(8, 2)
  speedRpm           Int?     @map("speed_rpm")
  sealType           String?  @map("seal_type") @db.VarChar(30)
  sealPlan           String?  @map("seal_plan") @db.VarChar(20)
  couplingType       String?  @map("coupling_type") @db.VarChar(30)
  sealFaceMaterial   String?  @map("seal_face_material") @db.VarChar(30)
  sealElastomer      String?  @map("seal_elastomer") @db.VarChar(20)
  // Baseplate customization
  baseplateFrameType String?  @map("baseplate_frame_type") @db.VarChar(30)
  baseplateMaterial  String?  @map("baseplate_material") @db.VarChar(50)
  baseplateHasDripRim Boolean @default(false) @map("baseplate_has_drip_rim")
  baseplateHasDrain  Boolean  @default(false) @map("baseplate_has_drain")
  baseplateGroutType String?  @map("baseplate_grout_type") @db.VarChar(30)
  baseplateDomestic  Boolean  @default(false) @map("baseplate_domestic")
  numStages          Int      @default(1) @map("num_stages")
  dutyFlowM3h        Decimal  @map("duty_flow_m3h") @db.Decimal(10, 2)
  dutyHeadM          Decimal  @map("duty_head_m") @db.Decimal(10, 2)
  npshaM             Decimal  @map("npsha_m") @db.Decimal(6, 2)
  fluidSg            Decimal  @default(1.0) @map("fluid_sg") @db.Decimal(6, 4)
  fluidTempC         Decimal? @map("fluid_temp_c") @db.Decimal(6, 1)
  validationStatus   String   @default("pending") @map("validation_status") @db.VarChar(20)
  validationMessages Json     @default("[]") @map("validation_messages")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  project            Project         @relation(fields: [projectId], references: [id])
  pumpSize           PumpSize        @relation(fields: [pumpSizeId], references: [id])
  motor              MotorOption?    @relation("ConfigurationMotor", fields: [motorOptionId], references: [id])
  baseplate          BaseplateOption? @relation("ConfigurationBaseplate", fields: [baseplateId], references: [id])
  materialSelections ComponentMaterialSelectionRecord[]

  @@map("pump_configuration")
}

model ComponentMaterialSelectionRecord {
  id                 String  @id @default(uuid())
  configurationId    String  @map("configuration_id")
  componentKey       String  @map("component_key") @db.VarChar(50)
  materialId         String  @map("material_id")
  coatingRequired    Boolean @default(false) @map("coating_required")
  coatingSpec        String? @map("coating_spec") @db.VarChar(100)
  cmtrRequired       Boolean @default(false) @map("cmtr_required")
  cmtrType           String? @map("cmtr_type") @db.VarChar(10)
  babaCompliant      Boolean? @map("baba_compliant")
  nsf61Compliant     Boolean? @map("nsf61_compliant")
  nsf372Compliant    Boolean? @map("nsf372_compliant")
  validationStatus   String  @default("valid") @map("validation_status") @db.VarChar(20)
  validationMessages Json    @default("[]") @map("validation_messages")

  configuration PumpConfigurationRecord @relation(fields: [configurationId], references: [id])
  material      Material                @relation(fields: [materialId], references: [id])

  @@unique([configurationId, componentKey])
  @@map("component_material_selection")
}

model ConfigurationRule {
  id                 String  @id @default(uuid())
  familyId           String? @map("family_id")
  hiTypeCode         String? @map("hi_type_code") @db.VarChar(10)
  ruleType           String  @map("rule_type") @db.VarChar(30)
  parameterName      String  @map("parameter_name") @db.VarChar(50)
  condition          Json
  action             Json
  certificationScope String? @map("certification_scope") @db.VarChar(30)
  priority           Int     @default(100)
  description        String? @db.Text

  @@map("configuration_rule")
}

// =============================================================================
// §5.6 Geometry Module Tables
// =============================================================================

model ImpellerGeometry {
  id                    String   @id @default(uuid())
  modelId               String?  @map("model_id")
  patternNumber         String?  @map("pattern_number") @db.VarChar(50)
  revision              String?  @db.VarChar(10)
  // Inlet
  d1Mm                  Decimal? @map("D1_mm") @db.Decimal(8, 2)
  dHubMm                Decimal? @map("D_hub_mm") @db.Decimal(8, 2)
  beta1HubDeg           Decimal? @map("beta1_hub_deg") @db.Decimal(6, 2)
  beta1ShroudDeg        Decimal? @map("beta1_shroud_deg") @db.Decimal(6, 2)
  b1Mm                  Decimal? @map("b1_mm") @db.Decimal(8, 2)
  // Vane
  z                     Int?     @map("Z")
  zSplit                Int?     @default(0) @map("Z_split")
  beta2Deg              Decimal? @map("beta2_deg") @db.Decimal(6, 2)
  thetaWrapDeg          Decimal? @map("theta_wrap_deg") @db.Decimal(6, 2)
  t1Mm                  Decimal? @map("t1_mm") @db.Decimal(6, 2)
  t2Mm                  Decimal? @map("t2_mm") @db.Decimal(6, 2)
  bladeProfileType      String?  @map("blade_profile_type") @db.VarChar(30)
  raCastUm              Decimal? @map("Ra_cast_um") @db.Decimal(6, 2)
  raMachinedUm          Decimal? @map("Ra_machined_um") @db.Decimal(6, 2)
  // Exit
  d2MaxMm               Decimal  @map("D2_max_mm") @db.Decimal(8, 2)
  b2Mm                  Decimal? @map("b2_mm") @db.Decimal(8, 2)
  a2TotalMm2            Decimal? @map("A2_total_mm2") @db.Decimal(12, 2)
  lOverlapOriginalMm    Decimal? @map("L_overlap_original_mm") @db.Decimal(8, 2)
  shroudExtensionMm     Decimal? @map("shroud_extension_mm") @db.Decimal(8, 2)
  // Shroud/Disk
  shroudType            String?  @map("shroud_type") @db.VarChar(20)
  dSealFMm              Decimal? @map("D_seal_f_mm") @db.Decimal(8, 2)
  dSealBMm              Decimal? @map("D_seal_b_mm") @db.Decimal(8, 2)
  hasBackVanes          Boolean  @default(false) @map("has_back_vanes")
  // Clearances
  deltaWrFMm            Decimal? @map("delta_wr_f_mm") @db.Decimal(6, 3)
  deltaWrBMm            Decimal? @map("delta_wr_b_mm") @db.Decimal(6, 3)
  wrType                String?  @map("wr_type") @db.VarChar(20)
  // Computed ratios
  blockageFactor        Decimal? @map("blockage_factor") @db.Decimal(6, 4)
  slipFactor            Decimal? @map("slip_factor") @db.Decimal(6, 4)
  // Metadata
  source                String?  @db.VarChar(30)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()

  model         PumpModel?           @relation(fields: [modelId], references: [id])
  modifications GeometryModification[] @relation("ImpellerModifications")
  testResults   GeometryTestResult[]

  @@map("impeller_geometry")
}

model VoluteGeometry {
  id                    String   @id @default(uuid())
  modelId               String?  @map("model_id")
  patternNumber         String?  @map("pattern_number") @db.VarChar(50)
  voluteType            String?  @map("volute_type") @db.VarChar(30)
  a3Mm2                 Decimal? @map("A3_mm2") @db.Decimal(12, 2)
  b3Mm                  Decimal? @map("b3_mm") @db.Decimal(8, 2)
  d3Mm                  Decimal? @map("D3_mm") @db.Decimal(8, 2)
  deltaCwMm             Decimal? @map("delta_cw_mm") @db.Decimal(8, 2)
  thetaCwDeg            Decimal? @map("theta_cw_deg") @db.Decimal(6, 2)
  cwLipProfile          String?  @map("cw_lip_profile") @db.VarChar(20)
  areaDistribution      Json?    @map("area_distribution")
  dBcMm                 Decimal? @map("D_bc_mm") @db.Decimal(8, 2)
  aDnMm2                Decimal? @map("A_dn_mm2") @db.Decimal(12, 2)
  hasSplitter           Boolean  @default(false) @map("has_splitter")
  hasDiffuserVanes      Boolean  @default(false) @map("has_diffuser_vanes")
  zD                    Int?     @map("Z_d")
  source                String?  @db.VarChar(30)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()

  model         PumpModel?           @relation(fields: [modelId], references: [id])
  modifications GeometryModification[] @relation("VoluteModifications")
  testResults   GeometryTestResult[]

  @@map("volute_geometry")
}

model GeometryModification {
  id                   String   @id @default(uuid())
  targetType           String   @map("target_type") @db.VarChar(20)
  impellerGeometryId   String?  @map("impeller_geometry_id")
  voluteGeometryId     String?  @map("volute_geometry_id")
  modificationCode     String   @map("modification_code") @db.VarChar(30)
  modificationCategory String   @map("modification_category") @db.VarChar(30)
  sequenceOrder        Int      @map("sequence_order")
  geometryBefore       Json     @map("geometry_before")
  geometryAfter        Json     @map("geometry_after")
  parameters           Json
  predictedEffect      Json?    @map("predicted_effect")
  datePerformed        DateTime? @map("date_performed") @db.Date
  performedBy          String?  @map("performed_by") @db.VarChar(100)
  notes                String?  @db.Text
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz()

  impellerGeometry ImpellerGeometry? @relation("ImpellerModifications", fields: [impellerGeometryId], references: [id])
  voluteGeometry   VoluteGeometry?   @relation("VoluteModifications", fields: [voluteGeometryId], references: [id])

  @@map("geometry_modification")
}

model GeometryTestResult {
  id                    String   @id @default(uuid())
  impellerGeometryId    String   @map("impeller_geometry_id")
  voluteGeometryId      String   @map("volute_geometry_id")
  d2ActualMm            Decimal  @map("D2_actual_mm") @db.Decimal(8, 2)
  trimRatio             Decimal? @map("trim_ratio") @db.Decimal(6, 4)
  beta2EffectiveDeg     Decimal? @map("beta2_effective_deg") @db.Decimal(6, 2)
  deltaCwActualMm       Decimal? @map("delta_cw_actual_mm") @db.Decimal(8, 2)
  areaRatioActual       Decimal? @map("area_ratio_actual") @db.Decimal(6, 4)
  bGapRatioActual       Decimal? @map("B_gap_ratio_actual") @db.Decimal(6, 4)
  overlapRatio          Decimal? @map("overlap_ratio") @db.Decimal(6, 4)
  nsActual              Decimal? @map("Ns_actual") @db.Decimal(10, 2)
  speedRpm              Int      @map("speed_rpm")
  fluidSg               Decimal  @default(1.0) @map("fluid_sg") @db.Decimal(6, 4)
  qBepM3h               Decimal? @map("Q_bep_m3h") @db.Decimal(10, 2)
  hBepM                 Decimal? @map("H_bep_m") @db.Decimal(10, 2)
  etaBepPct             Decimal? @map("eta_bep_pct") @db.Decimal(6, 2)
  pBepKw                Decimal? @map("P_bep_kw") @db.Decimal(10, 2)
  npshrAtBepM           Decimal? @map("NPSHr_at_bep_m") @db.Decimal(6, 2)
  hShutoffM             Decimal? @map("H_shutoff_m") @db.Decimal(10, 2)
  curveSetId            String?  @map("curve_set_id")
  modificationsApplied  Json?    @map("modifications_applied")
  testType              String?  @map("test_type") @db.VarChar(30)
  testDate              DateTime? @map("test_date") @db.Date
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()

  impellerGeometry ImpellerGeometry    @relation(fields: [impellerGeometryId], references: [id])
  voluteGeometry   VoluteGeometry      @relation(fields: [voluteGeometryId], references: [id])
  curveSet         PerformanceCurveSet? @relation(fields: [curveSetId], references: [id])

  @@index([nsActual], map: "idx_geom_test_ns")
  @@index([areaRatioActual], map: "idx_geom_test_area_ratio")
  @@index([trimRatio], map: "idx_geom_test_trim")
  @@map("geometry_test_result")
}
