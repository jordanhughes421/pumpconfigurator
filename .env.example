# PostgreSQL connection (used by Prisma and Docker Compose)
DATABASE_URL="postgresql://magnumopus:magnumopus@localhost:5432/magnumopus?schema=public"

# Docker Compose overrides (optional)
POSTGRES_USER=magnumopus
POSTGRES_PASSWORD=magnumopus
POSTGRES_DB=magnumopus
POSTGRES_PORT=5432

# API server
API_PORT=3001
